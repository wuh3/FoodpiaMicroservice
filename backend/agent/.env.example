# LLM
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Agent service
APP_NAME=foodopia-agent-service
HOST=0.0.0.0
PORT=8090
DEBUG=false

# MCP servers (Spring AI SSE endpoints)
# Local dev: localhost. Docker Compose stack: meal-service / customer-service hostnames.
MEAL_MCP_URL=http://localhost:8082/sse
CUSTOMER_MCP_URL=http://localhost:8083/sse

MCP_TIMEOUT_SECONDS=30
MCP_CONNECT_ON_STARTUP=true

# REST fallbacks (optional, for direct HTTP calls later)
MEAL_SERVICE_URL=http://localhost:8082
CUSTOMER_SERVICE_URL=http://localhost:8083
